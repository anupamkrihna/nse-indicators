/* test_sell.js — regression gate for Sell Watch v1.3 (guards + calibration).
   Sources the pure functions directly from Code.gs so the test cannot drift
   from deployed code. Node-only; run before every deploy. */
var fs = require('fs');
var src = fs.readFileSync('Code.gs', 'utf8');
var block = src.slice(src.indexOf('var SELL = {'), src.indexOf('/* ═══ FULL PER-STOCK COMPUTE'));
eval(block);   // defines SELL, sell* helpers, sellPack_, sellBrier_, sellReliability_

var pass = 0, fail = 0;
function ok(c, n) { if (c) pass++; else { fail++; console.log('  ✗ ' + n); } }
function approx(a, b, e, n) { ok(Math.abs(a - b) <= e, n + ' (' + a + ' vs ' + b + ')'); }

/* synthetic series */
function monoUp(n) { var a = [100]; for (var i = 1; i < n; i++) a.push(a[i - 1] * 1.002); return a; }
function monoDown(n) { var a = [100]; for (var i = 1; i < n; i++) a.push(a[i - 1] * 0.995); return a; }
function sawtooth(n, up, amp) { var a = [], v = 100, dir = 1, c = 0;
  for (var i = 0; i < n; i++) { a.push(v); v *= (dir > 0 ? 1 + amp : 1 - amp); if (++c >= up) { c = 0; dir = -dir; } } return a; }
function lcg(s){ s=s>>>0; return function(){ s=(1664525*s+1013904223)%4294967296; return s/4294967296; }; }

console.log('── sell-watch v1.3 regression ──');

/* 1–5 core distribution (unchanged) */
var up = sellConditional_(monoUp(400), SELL.H, SELL.N, SELL.BIN, SELL.MINBIN, SELL.TAIL);
approx(up.pFall, 0, 1e-9, 'monoUp pFall=0'); approx(up.lift, 0, 1e-9, 'monoUp lift=0');
var dn = sellConditional_(monoDown(400), SELL.H, SELL.N, SELL.BIN, SELL.MINBIN, SELL.TAIL);
approx(dn.pFall, 1, 1e-9, 'monoDown pFall=1'); approx(dn.tail, 1, 1e-9, 'monoDown tail=1');
ok(sellConditional_(monoUp(80), SELL.H, SELL.N, SELL.BIN, SELL.MINBIN, SELL.TAIL) === null, 'short series → null');
var saw = sellConditional_(sawtooth(700, 18, 0.02), SELL.H, SELL.N, SELL.BIN, SELL.MINBIN, SELL.TAIL);
ok(saw.lift > 0, 'sawtooth stretched → lift>0');
approx(saw.lift, saw.pFall - saw.baseRate, 1e-6, 'lift identity');

/* 6 bootstrap seeded determinism + bounds */
var b1 = sellBootstrap_(monoUp(400), SELL.H, SELL.BOOT_BLOCK, 400, lcg(1));
var b2 = sellBootstrap_(monoUp(400), SELL.H, SELL.BOOT_BLOCK, 400, lcg(1));
approx(b1, b2, 1e-12, 'bootstrap deterministic under fixed seed');
approx(b1, 0, 1e-9, 'bootstrap monoUp=0');
approx(sellBootstrap_(monoDown(400), SELL.H, SELL.BOOT_BLOCK, 400, lcg(1)), 1, 1e-9, 'bootstrap monoDown=1');

/* 7 sellPack_ reproducible (internal seed) */
var close = sawtooth(700, 18, 0.02);
var p1 = sellPack_(close, 'weak', { heading: 'death', etaDays: 12 });
var p2 = sellPack_(close, 'weak', { heading: 'death', etaDays: 12 });
ok(p1.grade === p2.grade && p1.bootstrap === p2.bootstrap, 'sellPack_ reproducible run-to-run');

/* 8 THE INDHOTEL FIX: high lift + near death cross, but bootstrap disagrees → capped, not A */
ok(p1.lift >= 0.15, 'case has strong lift ('+p1.lift+')');
ok(p1.divergent === true, 'bootstrap divergence detected (|pFall−boot|>0.15)');
ok(p1.grade === 'C', 'divergent case capped at C, NOT A  (grade='+p1.grade+')');
ok(p1.trust === 'low', 'trust flagged low');

/* 9 regime gate still suppresses trending */
var tr = sellPack_(close, 'trend', { heading: 'death', etaDays: 12 });
ok(tr.regime === 'TR' && tr.gated === true && tr.grade === '', 'trend → gated, no grade');

/* 10 invariant: no A/B grade may ever carry a low-trust flag (across many series) */
var clean = true;
for (var s = 0; s < 40; s++) {
  var series = sawtooth(500 + s * 5, 12 + (s % 10), 0.01 + (s % 5) * 0.004);
  var pk = sellPack_(series, s % 2 ? 'weak' : 'chop', { heading: 'none' });
  if ((pk.grade === 'A' || pk.grade === 'B') && (pk.thin || pk.divergent)) clean = false;
}
ok(clean, 'no A/B grade ever carries thin or divergent (guard invariant)');

/* 11 effN reflects overlapping-window collapse */
ok(Math.abs(p1.effN - p1.n / SELL.H) < 0.11, 'effN = n / horizon');

/* 12 Brier score exact values */
approx(sellBrier_([{p:1,y:1},{p:0,y:0}]), 0, 1e-9, 'Brier perfect = 0');
approx(sellBrier_([{p:0,y:1},{p:1,y:0}]), 1, 1e-9, 'Brier worst = 1');
approx(sellBrier_([{p:0.5,y:1},{p:0.5,y:0}]), 0.25, 1e-9, 'Brier 0.5 guesses = 0.25');
ok(sellBrier_([]) === null, 'Brier empty → null');

/* 13 reliability binning + perfect-calibration recovery */
var rel = sellReliability_([{p:0.05,y:0},{p:0.95,y:1},{p:0.95,y:1}], 10);
ok(rel.length === 10, 'reliability has 10 bins');
ok(rel[0].n === 1 && rel[9].n === 2, 'samples land in correct deciles');
approx(rel[9].observed, 1, 1e-9, 'top decile observed = 1 (both fell)');
approx(rel[0].observed, 0, 1e-9, 'bottom decile observed = 0');

console.log('── ' + pass + ' passed, ' + fail + ' failed ──');
process.exit(fail ? 1 : 0);
